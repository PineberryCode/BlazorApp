@rendermode InteractiveServer
@inject BlazorApp.Security.SessionService SessionService

<nav id="main-nav" class="navbar navbar-expand-lg">
    <div class="container justify-content-start align-items-center">
        <img src="@Assets["images/pj_logo_ceplan.png"]" alt="Logo Ceplan" style="height: 40px" />
    </div>
    <div class="container justify-content-end align-items-center gap-3">
        <i id="question-mark" class="bi bi-question"></i>
        <i id="bell" class="bi bi-bell-fill"></i>

        @if (_name != null)
        {
            <div class="d-flex align-items-center gap-2">
                <i id="user-icon" class="bi bi-person-fill text-white"></i
                <div class="d-flex flex-column" style="line-height: 1.2;">
                    <span style="font-size: 13px; font-weight: 500; color: #fff;">@_name</span>
                    <span style="font-size: 11px; color: #fff;">@_typeHire</span>
                </div>
            </div>
        }
    </div>
</nav>

@code {
    private string? _name;
    private string? _typeHire;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var isAuth = await SessionService.IsAuthenticatedAsync();
        if (!isAuth) return;

        _name      = $"{await SessionService.GetClaimAsync("father_lastname")}, {await SessionService.GetClaimAsync("names")}";
        _typeHire  = await SessionService.GetClaimAsync("type_hire");
        StateHasChanged();
    }
}