@page "/login"
@using System.Runtime.CompilerServices
@using BlazorApp.Controllers
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject BlazorApp.Controllers.LoginController LoginController
@inject BlazorApp.Controllers.NotificationController NotificationController;

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "SessionExpired")]
    public bool SessionExpired { get; set; }
    private bool _showSessionExpiredAlert = false;

    protected override void OnInitialized() {
        if (SessionExpired)
        {
            _showSessionExpiredAlert = true;
            
            Task.Delay(5000).ContinueWith(_ => 
            {
                _showSessionExpiredAlert = false;
                InvokeAsync(StateHasChanged);
            });
        }
    }

    // Variables and func from controller
    private string dni = string.Empty;
    private string password = string.Empty;
    private string ? errorMessageUser;
    private string ? errorMessagePassword;
    private bool isLoading = false;
    private int counterErr = 1;

    private async Task HandleSignIn() {
        errorMessageUser = null;
        errorMessagePassword = null;
        isLoading = true;
        StateHasChanged();
        await Task.Delay(500);

        if (counterErr == 5) {
            await NotificationController.SendByDniAsync(
                dni: dni, 
                subject: "Testing ASP.NET", 
                body: "<h1>Cuenta bloqueada por superar el límite de intentos.</h1>"
            );
            isLoading = false;
            Navigation.NavigateTo("/blocked");
            return;
        }

        var employee = await LoginController.SignIn(dni, password);
        isLoading = false;

        if (employee == false) {
            errorMessageUser = "Usuario incorrecto";
            errorMessagePassword = "Contraseña incorrecta";
            counterErr++;
            return;
        }

        Navigation.NavigateTo("/profile");
    }

    //Variables and func for interface
    private bool isPasswordVisible = false;
    private string passwordInputType => isPasswordVisible ? "text" : "password";
    private string passwordIcon => isPasswordVisible ? "bi-eye-slash" : "bi-eye";

    private void SeePassword() 
    {
        isPasswordVisible = !isPasswordVisible;
    }
}

<div class="d-flex flex-column justify-content-center align-items-center flex-grow-1 mt-3" style="min-height: 80vh;">
    <div class="card border-0">
        <div id="card-body" class="card-body text-center">
            <ul id="tab-content" class="nav nav-pills nav-fill py-2">
                <li id="tab-dni" class="nav-item">
                    <a id="text-dni" class="nav-link" href="/login">DNI</a>
                </li>
                <li id="tab-ce" class="nav-item border border-secondary">
                    <a id="text-ce" class="nav-link">CE</a>
                </li>
            </ul>
            <form>
                @*User input*@
                <div class="form-group">
                    <label class="d-flex justify-self-content-start">Usuario</label>
                    <div class="input-group custom-input-group mb-3">
                        <span class="input-group-text bg-white border-end-0 @(errorMessageUser != null ? "border-left border-top border-bottom border-danger" : "")">
                            <i class="bi bi-person text-muted"></i>
                        </span>
                        <input 
                            class="form-control border-start-0 @(errorMessageUser != null ? "border border-danger" : "")" 
                            placeholder="Ingresar usuario" 
                            @bind="dni"
                            @bind:event="oninput" 
                        />
                    </div>
                    @if (errorMessageUser != null) {
                        <div class="d-flex justify-self-start gap-2">
                            <i class="err-msg bi bi-info-circle-fill"></i>
                            <p class="err-msg">@errorMessageUser</p>
                        </div>
                    }
                </div>
                @*Password input*@
                <div class="form-group">
                    <label class="d-flex justify-self-content-start">Contraseña</label>
                    <div class="input-group custom-input-group mb-3">
                        <span class="input-group-text bg-white border-end-0 @(errorMessagePassword != null ? "border-left border-top border-bottom border-danger" : "")">
                            <i class="bi bi-lock text-muted"></i>
                        </span>
                        <input 
                            class="form-control border-start-0  @(errorMessagePassword != null ? "border border-danger" : "")" 
                            type="@passwordInputType" 
                            placeholder="Ingresar contraseña" 
                            @bind="password"
                            @bind:event="oninput"
                        />
                        <button class="input-group-text bg-white border-start-0 text-muted @(errorMessagePassword != null ? "border-top border-bottom border-right border-danger" : "")" 
                            type="button" 
                            @onclick="SeePassword">
                                <i class="bi @passwordIcon"></i>
                        </button>
                    </div>
                    @if (errorMessagePassword != null) {
                        <div class="d-flex justify-content-start gap-2">
                            <i class="err-msg bi bi-info-circle-fill"></i>
                            <p class="err-msg">@errorMessagePassword</p>
                        </div>
                    }
                </div>
            </form>

            <a href="#" class="d-flex justify-content-start my-3">¿Olvidó su contraseña?</a>
            <button 
                class="btn btn-primary w-100 d-flex justify-content-center m-auto" 
                @onclick="HandleSignIn" 
                disabled="@(isLoading || string.IsNullOrWhiteSpace(dni) || string.IsNullOrWhiteSpace(password))"
            >
                @if (isLoading) {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                } else {
                    <p class="d-flex align-items-center">Ingresar</p>
                }
            </button>
        </div>
    </div>

    <div class="d-flex flex-column justify-content-center align-items-center flex-grow-1">
        <div class="card border-0">
            <div class="card-body d-flex justify-content-center">
                <img src="@Assets["images/ceplan-illustration-support.png"]" alt="Logo support" />
                <p>¿Necesita ayuda?, </p>
                <a href="#">contacte con el área de soporte.</a>
            </div>
        </div>
    </div>
    @if (_showSessionExpiredAlert)
    {
        <div class="alert alert-info shadow-lg position-fixed bottom-0 end-0 m-4 d-flex align-items-center gap-3 border-0 border-start border-4 border-info" 
            style="z-index: 1050; min-width: 300px; background-color: #f0f7ff;">
            <i class="bi bi-info-circle-fill text-info fs-4"></i>
            <div>
                <span class="text-muted small">Su sesión ha expirado por inactividad. Por favor, incie sesión nuevamente.</span>
            </div>
            <button type="button" class="btn-close ms-auto" @onclick="() => _showSessionExpiredAlert = false"></button>
        </div>
    }
</div>